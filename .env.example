# Lovable FE Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy file này thành `.env` ở root project Lovable (cùng cấp với package.json).
# Tất cả biến phải prefix bằng VITE_ để Vite expose ra frontend.

# Backend Express API base URL
# ─────────────────────────────
# Local development (BE chạy trên máy user, dùng IP LAN nếu test trên TV/phone):
VITE_API_BASE_URL=http://localhost:3000

# Nếu Lovable dev chạy ở máy khác và BE ở máy user, dùng IP LAN:
# VITE_API_BASE_URL=http://192.168.1.100:3000

# Production (sau khi deploy BE lên VPS):
# VITE_API_BASE_URL=https://api.moviecc.vip

# CSRF Token Cookie Name
# ──────────────────────
# Backend Express set cookie với tên "csrf_token" (Lovable format).
# FE đọc cookie này rồi attach vào header X-CSRF-Token cho mọi POST/PUT/DELETE.
VITE_CSRF_COOKIE_NAME=csrf_token
VITE_CSRF_HEADER_NAME=X-CSRF-Token

# Session Cookie Name
# ───────────────────
# FE đọc cookie session để biết user đã login chưa.
# Không cần dùng trực tiếp — chỉ cần `credentials: 'include'`.
VITE_SESSION_COOKIE_NAME=connect.sid

# Image Proxy (optional)
# ──────────────────────
# Nếu muốn resolve ảnh qua proxy để bypass CORS / hotlink protection:
VITE_IMAGE_PROXY_BASE=http://localhost:3000/api/react/image

# Feature Flags (optional, override defaults)
# ─────────────────────────────────────────────
# Bật/tắt các tính năng cụ thể nếu BE chưa sẵn sàng:
VITE_FEATURE_FEEDBACK=true
VITE_FEATURE_WATCHLIST=true
VITE_FEATURE_NOTIFICATIONS=true
