# Server
PORT=3000
NODE_ENV=development

# Security
SESSION_SECRET=your-random-session-secret-here
ENCRYPT_KEY=your-random-encrypt-key-here
HEALTH_SECRET=your-health-check-secret-here
BUSINESS_API_KEY=your-third-party-account-api-key-here

# Site URL (no trailing slash)
SITE_URL=https://moviecc.app

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/moviecc

# Movie Providers
OPHIM_BASE_URL=https://ophim1.com
OPHIM_CDN_IMAGE=https://img.ophim.live
KKPHIM_BASE_URL=https://phimapi.com
KKPHIM_CDN_IMAGE=https://phimimg.com
ENABLE_OPHIM=true
ENABLE_KKPHIM=true
ENABLE_NGUONC=false
NGUONC_BASE_URL=https://phim.nguonc.com

# Features
REQUIRE_AUTH=true
ENABLE_FEEDBACK=true
MAX_CCU_PER_WORKER=30

# Cloudflare Turnstile (get keys at https://dash.cloudflare.com/turnstile)
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Set to true in development to skip Turnstile verification (ONLY FOR LOCAL DEV)
# FORCE_TURNSTILE=true

# Optimization
OPTIMIZE_IMAGES=true
