<div class="container">
    <div class="section-header" style="margin-top: 20px">
        <h2 class="section-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
            </svg>
            Lịch sử xem phim
        </h2>
        <% if (history && history.length> 0) { %>
            <button class="btn btn-ghost btn-sm" data-action="clearAllHistory" id="clearHistoryBtn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                </svg>
                Xóa tất cả
            </button>
            <% } %>
    </div>

    <% if (!history || history.length===0) { %>
        <div class="history-empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                style="color: var(--text-muted); margin-bottom: 16px">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
            </svg>
            <h3>Chưa có lịch sử xem</h3>
            <p>Bắt đầu xem phim để lịch sử được lưu tại đây</p>
            <a href="/" class="btn btn-primary" style="margin-top: 16px">Khám phá phim</a>
        </div>
        <% } else { %>
            <div class="history-list">
                <% history.forEach(function(item) { %>
                    <div class="history-item" id="history-<%= item.id %>">
                        <a href="/xem/<%= item.movie_slug %>/<%= item.episode_slug %>" class="history-thumb-link">
                            <div class="history-thumb <%= item.movie_thumb ? 'skeleton' : '' %>">
                                <% if (item.movie_thumb) { %>
                                    <img src="<%= item.movie_thumb %>" alt="<%= item.movie_name %>" loading="lazy"
                                        data-skeleton-parent
                                        data-fallback="/images/no-poster.svg" data-fallback-class="skeleton">
                                    <% } else { %>
                                        <div class="history-thumb-placeholder">
                                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="1.5">
                                                <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18" />
                                                <line x1="7" y1="2" x2="7" y2="22" />
                                                <line x1="17" y1="2" x2="17" y2="22" />
                                                <line x1="2" y1="12" x2="22" y2="12" />
                                                <line x1="2" y1="7" x2="7" y2="7" />
                                                <line x1="2" y1="17" x2="7" y2="17" />
                                                <line x1="17" y1="7" x2="22" y2="7" />
                                                <line x1="17" y1="17" x2="22" y2="17" />
                                            </svg>
                                        </div>
                                        <% } %>
                                            <% if (item.duration> 0) { %>
                                                <div class="history-progress-bar">
                                                    <div class="history-progress-fill"
                                                        style="width: <%= Math.min(100, Math.round((item.current_time / item.duration) * 100)) %>%">
                                                    </div>
                                                </div>
                                                <% } %>
                                                    <div class="history-play-overlay">
                                                        <svg width="28" height="28" viewBox="0 0 24 24"
                                                            fill="currentColor">
                                                            <polygon points="5 3 19 12 5 21 5 3" />
                                                        </svg>
                                                    </div>
                            </div>
                        </a>
                        <div class="history-info">
                            <a href="/phim/<%= item.movie_slug %>" class="history-title">
                                <%= item.movie_name || item.movie_slug %>
                            </a>
                            <% if (item.movie_origin_name) { %>
                                <div class="history-origin-name">
                                    <%= item.movie_origin_name %>
                                </div>
                                <% } %>
                                    <div class="history-meta">
                                        <span class="history-episode">
                                            <% if (item.episode_slug==='full' || item.episode_slug==='Full' ) { %>Full<%
                                                    } else { %>Tập
                                                    <%= item.episode_slug %>
                                                        <% } %>
                                        </span>
                                        <% if (item.duration> 0) { %>
                                            <span class="history-time">
                                                <%= Math.floor(item.current_time / 60) %>:<%= String(item.current_time %
                                                        60).padStart(2, '0' ) %>
                                                        / <%= Math.floor(item.duration / 60) %>:<%= String(item.duration
                                                                % 60).padStart(2, '0' ) %>
                                            </span>
                                            <% } %>
                                    </div>
                                    <div class="history-date">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10" />
                                            <polyline points="12 6 12 12 16 14" />
                                        </svg>
                                        <%= new Date(item.last_watched).toLocaleDateString('vi-VN', { day: '2-digit' ,
                                            month: '2-digit' , year: 'numeric' , hour: '2-digit' , minute: '2-digit' })
                                            %>
                                    </div>
                        </div>
                        <div class="history-actions">
                            <a href="/xem/<%= item.movie_slug %>/<%= item.episode_slug %>"
                                class="btn btn-primary btn-sm">Tiếp
                                tục</a>
                            <button type="button" class="btn btn-ghost btn-sm history-remove-btn" data-action="removeHistory" data-id="<%= item.id %>" title="Bỏ xem">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" aria-hidden="true">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                                <span class="history-remove-label">Bỏ xem</span>
                            </button>
                        </div>
                    </div>
                    <% }); %>
            </div>

            <% if (totalPages > 1) { %>
            <div class="pagination" style="margin-top:24px">
                <% if (currentPage > 1) { %>
                    <a href="/lich-su?page=<%= currentPage - 1 %>" class="pagination-arrow">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </a>
                <% } %>
                <% const _startH = Math.max(1, currentPage - 2); const _endH = Math.min(totalPages, currentPage + 2); %>
                <% if (_startH > 1) { %>
                    <a href="/lich-su?page=1">1</a>
                    <% if (_startH > 2) { %><span class="pagination-dots">…</span><% } %>
                <% } %>
                <% for (let p = _startH; p <= _endH; p++) { %>
                    <% if (p === currentPage) { %>
                        <span class="active"><%= p %></span>
                    <% } else { %>
                        <a href="/lich-su?page=<%= p %>"><%= p %></a>
                    <% } %>
                <% } %>
                <% if (_endH < totalPages) { %>
                    <% if (_endH < totalPages - 1) { %><span class="pagination-dots">…</span><% } %>
                    <a href="/lich-su?page=<%= totalPages %>"><%= totalPages %></a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                    <a href="/lich-su?page=<%= currentPage + 1 %>" class="pagination-arrow">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </a>
                <% } %>
            </div>
            <% } %>
                    <% } %>
</div>
