<div class="error-page">
    <div class="error-content">
        <div class="error-code">
            <span class="digit">4</span>
            <span class="digit zero">
                <svg viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="8"
                        stroke-dasharray="8 12" />
                    <circle cx="35" cy="42" r="5" fill="currentColor" />
                    <circle cx="65" cy="42" r="5" fill="currentColor" />
                    <path d="M 35 65 Q 50 55 65 65" fill="none" stroke="currentColor" stroke-width="4"
                        stroke-linecap="round" />
                </svg>
            </span>
            <span class="digit">4</span>
        </div>
        <h1 class="error-title"><%= typeof errorTitle !== 'undefined' ? errorTitle : 'Trang không tồn tại' %></h1>
        <p class="error-desc"><%= typeof errorDesc !== 'undefined' ? errorDesc : 'Trang bạn đang tìm kiếm có thể đã bị xóa, đổi tên hoặc tạm thời không khả dụng.' %></p>
        <div class="error-actions">
            <a href="/" class="btn-back-home">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                Về trang chủ
            </a>
            <a href="/tim-kiem" class="btn-search-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                Tìm kiếm phim
            </a>
        </div>
    </div>
    <div class="error-bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
</div>