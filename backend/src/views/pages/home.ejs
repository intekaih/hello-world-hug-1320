                                                                                            <div class="landscape-card-content">
                                                                                                <div class="landscape-card-title"><%= movie.name %></div>
                                                                                                <div class="landscape-card-meta">
                                                                                                    <% if (movie.rating && movie.rating > 0) { %>
                                                                                                        <span class="landscape-card-rating">
                                                                                                            <svg width="11" height="11" viewBox="0 0 24 24" fill="#ffc107"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                                                                                            <%= movie.rating.toFixed(1) %>
                                                                                                        </span>
                                                                                                        <span class="lc-dot"></span>
                                                                                                    <% } %>
                                                                                                    <% if (movie.year && movie.year > 0) { %><span><%= movie.year %></span><% } %>
                                                                                                    <span class="lc-dot"></span>
                                                                                                    <span><%= movie.quality %></span>
                                                                                                    <% if (movie.time) { %><span class="lc-dot"></span><span><%= movie.time %></span><% } %>
                                                                                                </div>
                                                                                            </div>
                                                                                        </a>
                                                                                    <% }); %>
                                                                                </div>
                                                                            </section>
                                                                        <% } %>

                                                                                <!-- ===== Thịnh Hành — Horizontal Scroll Row ===== -->
                                                                                <% if (hotMovies && hotMovies.length> 0) { %>
                                                                                    <section class="section">
                                                                                        <div class="section-header">
                                                                                            <h2 class="section-title">
                                                                                                Thịnh Hành
                                                                                            </h2>
                                                                                            <a href="/danh-sach/phim-bo-dang-chieu"
                                                                                                class="section-link">
                                                                                                Xem tất cả
                                                                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                                    <polyline points="9 18 15 12 9 6" />
                                                                                                </svg>
                                                                                            </a>
                                                                                        </div>
                                                                                        <div class="movie-row">
                                                                                            <button class="row-arrow row-arrow-left" data-action="scrollRow" data-dir="-1" aria-label="Cuộn trái">
                                                                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6" /></svg>
                                                                                            </button>
                                                                                            <div class="movie-row-track">
                                                                                                <% hotMovies.forEach(movie=> { %>
                                                                                                    <%- include('../partials/movie-card', { movie }) %>
                                                                                                <% }); %>
                                                                                            </div>
                                                                                            <button class="row-arrow row-arrow-right" data-action="scrollRow" data-dir="1" aria-label="Cuộn phải">
                                                                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6" /></svg>
                                                                                            </button>
                                                                                        </div>
                                                                                    </section>
                                                                                    <% } %>

                                                                                    <!-- ===== Anime — Cinematic Glow (conic gradient) ===== -->
                                                                                    <% if (typeof animeMovies !== 'undefined' && animeMovies && animeMovies.length > 0) { %>
                                                                                    <section class="section">
                                                                                        <div class="section-header">
                                                                                            <h2 class="section-title">
                                                                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="margin-right:2px">
                                                                                                    <circle cx="12" cy="12" r="10" />
                                                                                                    <path d="M8 14s1.5 2 4 2 4-2 4-2" />
                                                                                                    <line x1="9" y1="9" x2="9.01" y2="9" />
                                                                                                    <line x1="15" y1="9" x2="15.01" y2="9" />
                                                                                                </svg>
                                                                                                Anime Hay
                                                                                            </h2>
                                                                                            <a href="/danh-sach/hoat-hinh" class="section-link">
                                                                                                Xem tất cả
                                                                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                                                                                            </a>
                                                                                        </div>
                                                                                        <div class="anime-grid">
                                                                                            <% animeMovies.slice(0, 12).forEach(movie => { %>
                                                                                                <a href="/phim/<%= movie.slug %>" class="anime-card">
                                                                                                    <div class="anime-card-inner">
                                                                                                        <div class="anime-card-img" style="background-image:url('<%= movie.thumb_url %>')"></div>
                                                                                                        <div class="anime-card-overlay"></div>
                                                                                                        <div class="anime-card-info">
                                                                                                            <div class="anime-card-name"><%= movie.name %></div>
                                                                                                            <span class="anime-card-ep"><%= movie.episode_current %></span>
                                                                                                        </div>
                                                                                                        <div class="anime-card-tag">A</div>
                                                                                                    </div>
                                                                                                </a>
                                                                                            <% }); %>
                                                                                        </div>
                                                                                    </section>
                                                                                    <% } %>

