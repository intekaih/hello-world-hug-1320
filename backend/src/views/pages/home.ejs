                    %>
                        <div class="hero-thumb <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>">
                            <img src="<%= thumbUrl %>" alt="<%= movie.name %>" loading="<%= index < 3 ? 'eager' : 'lazy' %>"
                                width="120" height="180" data-fallback="/images/no-poster.svg">
                            <div class="hero-thumb-progress"></div>
                        </div>
                        <% }); %>
                </div>

                <!-- Mobile Dot Indicators -->
                <div class="hero-dots" id="heroDots">
                    <% heroMovies.forEach((movie, index)=> { %>
                        <button class="hero-dot <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>"
                            aria-label="Chuyển đến slide <%= index + 1 %>"></button>
                        <% }); %>
                </div>

                <!-- Slide Progress Bar -->
                <div class="hero-progress">
                    <div class="hero-progress-bar" id="heroProgressBar"></div>
                </div>
    </section>

    <!-- Preload Hero Images Script — chạy sau khi load trang để tránh block spinner -->
    <script nonce="<%= nonce %>">
    window.addEventListener('load', function() {
        var heroSlider = document.getElementById('heroSlider');
        if (!heroSlider) return;
        var slides = heroSlider.querySelectorAll('.hero-slide');
        var totalSlides = slides.length;
        if (totalSlides === 0) return;

        // Load ảnh cho các slides (từ slide 1)
        slides.forEach(function(slide, index) {
            if (index === 0) return; // Slide đầu đã được preload bằng <link rel="preload">
            var movieData = slide.dataset.movie ? JSON.parse(slide.dataset.movie) : null;
            if (!movieData) return;
            
            var imgUrl = movieData.backdrop_url || movieData.poster_url || movieData.thumb_url;
            if (!imgUrl) return;

            // Slide tiếp: lazy load sau khi trang đã load xong
            setTimeout(function() {
                var img = new Image();
                img.src = imgUrl;
            }, index * 300);
        });

        // Preload thumbnail images (2-3 thumbnail đầu)
        var thumbs = heroSlider.querySelectorAll('.hero-thumb img');
        thumbs.forEach(function(img, index) {
            if (index < 3 && img.src && !img.complete) {
                var preloadImg = new Image();
                preloadImg.src = img.src;
            }
        });
    });
    </script>
    <% } %>

