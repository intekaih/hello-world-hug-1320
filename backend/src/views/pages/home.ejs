<% if (heroMovies && heroMovies.length> 0) { %>
    <!-- Preload First Hero Image for LCP — ưu tiên backdrop_url (TMDB, ảnh ngang HD) -->
    <% const firstHeroUrl = heroMovies[0].backdrop_url || heroMovies[0].poster_url || heroMovies[0].thumb_url || ''; %>
    <link rel="preload" as="image" href="<%= firstHeroUrl %>" fetchpriority="high">
    <!-- Hero Slider -->
    <section class="hero-slider" id="heroSlider">
        <% heroMovies.forEach((movie, index)=> {
            // Ưu tiên: backdrop_url (TMDB, ảnh ngang HD) > poster_url > thumb_url
            const heroImageUrl = movie.backdrop_url || movie.poster_url || movie.thumb_url || '';
            // Serialize movie data cho JavaScript
            const movieData = {
                slug: movie.slug,
                name: movie.name,
                episode_current: movie.episode_current,
                epSlug: movie.epSlug || null,
                backdrop_url: movie.backdrop_url || null,
                poster_url: movie.poster_url || null,
                thumb_url: movie.thumb_url || null
            };
        %>
            <div class="hero-slide <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>" data-movie="<%= JSON.stringify(movieData) %>">
                <div class="hero-bg" data-bg="<%= heroImageUrl %>"></div>
                <div class="hero-overlay"></div>
                <div class="hero-content">
                    <div class="hero-badge">
                        <span class="badge-quality">
                            <%= movie.quality %>
                        </span>
                        <span class="badge-lang">
                            <%= movie.lang %>
                        </span>
                        <span class="badge-ep">
                            <%= movie.episode_current %>
                        </span>
                        <% if (movie.rating && movie.rating> 0) { %>
                            <span
                                class="rating-badge <%= movie.rating >= 7 ? 'rating-high' : movie.rating >= 5 ? 'rating-mid' : 'rating-low' %>">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                    <polygon
                                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                                </svg>
                                <%= movie.rating.toFixed(1) %>
                            </span>
                            <% } %>
                    </div>
                    <% if (movie.logo_url) { %>
                    <img
                        class="hero-logo"
                        src="<%= movie.logo_url %>"
                        alt="<%= movie.name %>"
                        crossorigin="anonymous"
                        data-remove-bg="1"
                    >
                    <h2 class="hero-title hero-title-hidden"><%= movie.name %></h2>
                    <% } else { %>
                    <h2 class="hero-title"><%= movie.name %></h2>
                    <% } %>
                    <p class="hero-subtitle">
                        <%= movie.origin_name %><% if (movie.year && movie.year > 0) { %> (<%= movie.year %>)<% } %>
                    </p>
                    <% if (movie.content) { %>
                        <p class="hero-desc"><%- movie.content.replace(/<[^>]*>/g, '').substring(0, 180)
                                %>...</p>
                        <% } %>
